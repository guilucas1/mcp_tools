# ============================================
# Build Stage - Contains build tools and cache
# ============================================
FROM python:3.10-slim AS builder

# Only install essential build dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        && \
    rm -rf /var/lib/apt/lists/*

# Install uv for dependency management
COPY --from=ghcr.io/astral-sh/uv:0.5.9 /uv /usr/local/bin/uv

# Set working directory for the repo
WORKDIR /build

# Clone the minima repository (shallow clone to save space)
RUN git clone --depth=1 https://github.com/dmayboroda/minima.git

# Set up the environment for MCP server
WORKDIR /build/minima/mcp-server

# Create a virtual environment within the project directory
RUN uv venv .venv

# Install dependencies in editable mode
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install -e .

# Also create a virtual environment for the indexer
WORKDIR /build/minima/indexer
RUN uv venv .venv
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install -e . || uv pip install -r requirements.txt || uv pip install fastapi uvicorn sentence-transformers qdrant-client langchain

# ============================================
# Runtime Stage - Minimal image with only required components
# ============================================
FROM python:3.10-slim AS runtime

# Install minimal runtime dependencies including netstat
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        procps \
        netcat-traditional \
        net-tools \
        && \
    rm -rf /var/lib/apt/lists/*

# Copy uv from builder stage
COPY --from=builder /usr/local/bin/uv /usr/local/bin/uv

# Create non-root user for security
RUN groupadd --gid 1001 app && \
    useradd --uid 1001 --gid app --shell /bin/bash --create-home app

# Copy only the necessary files from the builder stage
COPY --from=builder --chown=app:app /build/minima /app/minima

# Create directories for data and documents
RUN mkdir -p /app/data /app/documents && \
    chown -R app:app /app

WORKDIR /app

# Copy the startup script
COPY --chown=app:app docker-entrypoint.sh /app/
RUN chmod +x /app/docker-entrypoint.sh

# Switch to non-root user
USER app

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    LOCAL_FILES_PATH=/app/documents \
    PATH="/app/minima/indexer/.venv/bin:/app/minima/mcp-server/.venv/bin:$PATH"

# Healthcheck to make sure the process is running
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD ps aux | grep -q "[m]inima" || exit 1

# Expose the server port
EXPOSE 8000 8001

# Use the entrypoint script to run the MCP server
ENTRYPOINT ["/app/docker-entrypoint.sh"]